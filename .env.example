# Copy this file to .env and fill in real values.
# Never commit .env — only this template (.env.example) is tracked.

# Mapbox — get a token at https://account.mapbox.com/access-tokens/
# IMPORTANT: restrict the token to your production domain in the Mapbox dashboard
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Supabase — get these from https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase server-side (used by /api/* edge functions on Vercel).
# Plain (un-prefixed) names — NOT exposed to the browser.
# Set these on Vercel: Project → Settings → Environment Variables.
#   SUPABASE_URL              = same value as VITE_SUPABASE_URL
#   SUPABASE_SERVICE_ROLE_KEY = service_role key (Supabase → Settings → API).
#                               ⚠️  NEVER expose this to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional — Bitcoin address for the Donate modal. Leave empty to hide the button.
VITE_BTC_ADDRESS=
